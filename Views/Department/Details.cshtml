@model JO_UNI_Guide.Models.Department

@{
    ViewData["Title"] = "Department Profile";
    Layout = "_AdminLayout";
}

<div class="container py-4">

    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div>
            <h2 class="page-title mb-1">Department Details</h2>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0 small">
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none text-primary">Departments</a></li>
                    <li class="breadcrumb-item active text-muted" aria-current="page">@Model.DepartmentName</li>
                </ol>
            </nav>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model.Department_ID" class="btn btn-warning text-white rounded-pill px-4 shadow-sm">
                <i class="bi bi-pencil-square me-2"></i> Edit
            </a>
            <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4 shadow-sm">
                <i class="bi bi-arrow-left me-2"></i> Back
            </a>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-5">
            <div class="card shadow-sm border-0 rounded-4 p-4 h-100 bg-white">
                <h5 class="fw-bold text-secondary border-bottom pb-3 mb-4">
                    <i class="bi bi-info-square me-2 text-primary"></i> Department Info
                </h5>

                <div class="mb-4">
                    <label class="text-muted small fw-bold d-block mb-1">Department Name</label>
                    <h4 class="text-dark fw-bold">@Model.DepartmentName</h4>
                </div>

                <div class="mb-4 p-3 bg-light rounded-3 border">
                    <label class="text-muted small fw-bold d-block mb-1">Faculty</label>
                    <span class="text-dark fw-bold"><i class="bi bi-mortarboard me-2"></i> @Model.Faculty?.Name</span>
                </div>

                <div class="mb-4 p-3 bg-light rounded-3 border">
                    <label class="text-muted small fw-bold d-block mb-1">University</label>
                    <span class="text-dark fw-bold"><i class="bi bi-building me-2"></i> @Model.Faculty?.University?.Name</span>
                </div>
            </div>
        </div>

        <div class="col-lg-7">
            <div class="card shadow-sm border-0 rounded-4 p-4 h-100 bg-white">
                <div class="d-flex justify-content-between align-items-center border-bottom pb-3 mb-4">
                    <h5 class="fw-bold text-secondary mb-0">
                        <i class="bi bi-book me-2 text-success"></i> Department Courses
                    </h5>
                    <span class="badge bg-success rounded-pill px-3 py-2">
                        @(Model.Courses?.Count() ?? 0) Courses
                    </span>
                </div>

                @if (Model.Courses != null && Model.Courses.Any())
                {
                    <div class="list-group list-group-flush shadow-none">
                        @foreach (var course in Model.Courses)
                        {
                            <a asp-controller="Course" asp-action="Details" asp-route-id="@course.Course_ID"
                               class="list-group-item list-group-item-action d-flex justify-content-between align-items-center border rounded-3 mb-2 p-3 bg-white"
                               style="transition: 0.2s;">
                                <div>
                                    <i class="bi bi-journal-text text-primary me-2"></i>
                                    <span class="fw-bold">@course.Course_Name</span>
                                </div>
                                <i class="bi bi-chevron-right text-muted small"></i>
                            </a>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center py-5 bg-light rounded-3 border border-dashed">
                        <i class="bi bi-journal-x fs-1 text-muted d-block mb-2"></i>
                        <p class="text-muted mb-0">No courses added yet to this department.</p>
                        <a asp-controller="Course" asp-action="Create" class="btn btn-link text-primary btn-sm mt-2">+ Add First Course</a>
                    </div>
                }
            </div>
        </div>
    </div>

</div>

@section Scripts {
    <style>
        .list-group-item:hover {
            border-color: #0d6efd !important;
            background-color: #f8f9fa !important;
            transform: translateX(5px);
        }
    </style>
}