@model JO_UNI_Guide.Helpers.PaginatedList<JO_UNI_Guide.Models.Department>

@{
    ViewData["Title"] = "Departments";
    Layout = "_AdminLayout";
}

<div class="container py-4">

    @* Header Section *@
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div>
            <h2 class="page-title mb-0">Departments</h2>
            <p class="text-muted small">Manage admission rates, tuition fees, and credit hours</p>
        </div>
        <div class="d-flex gap-2">
            @* زر تحميل Excel الذي تحدثنا عنه سابقاً *@
            <a asp-action="ExportToExcel" class="btn btn-outline-success rounded-pill px-3 shadow-sm">
                <i class="bi bi-file-earmark-excel me-1"></i> Export
            </a>
            <a asp-action="Create" class="btn btn-primary px-4 rounded-pill shadow-sm">
                <i class="bi bi-plus-lg me-2"></i> Add Department
            </a>
        </div>
    </div>

    @* Advanced Search & Filter Section *@
    <div class="card shadow-sm border-0 mb-4 rounded-4 p-3 bg-white">
        <form asp-action="Index" method="get">
            <div class="row g-3">
                <div class="col-md-3">
                    <label class="small fw-bold text-muted">Search Name</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0"><i class="bi bi-search"></i></span>
                        <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" class="form-control border-start-0 bg-light" placeholder="Dept or Faculty..." />
                    </div>
                </div>

                @* الفلتر الجديد: نوع الجامعة *@
                <div class="col-md-2">
                    <label class="small fw-bold text-muted">Uni Type</label>
                    <select name="uniType" class="form-select bg-light" asp-items="Html.GetEnumSelectList<UniversityType>()">
                        <option value="">-- All --</option>
                    </select>
                </div>

                <div class="col-md-2">
                    <label class="small fw-bold text-muted">Min Rate (%)</label>
                    <input type="number" step="0.1" name="minRate" value="@ViewData["MinRate"]" class="form-control bg-light" placeholder="e.g. 80" />
                </div>

                <div class="col-md-2">
                    <label class="small fw-bold text-muted">Max Price (JOD)</label>
                    <input type="number" step="0.5" name="maxPrice" value="@ViewData["MaxPrice"]" class="form-control bg-light" placeholder="e.g. 50" />
                </div>

                <div class="col-md-3 d-flex align-items-end gap-2">
                    <button type="submit" class="btn btn-dark w-100 shadow-sm">Filter</button>
                    <a asp-action="Index" class="btn btn-outline-secondary w-100 shadow-sm text-center">
                        <i class="bi bi-arrow-counterclockwise"></i>
                    </a>
                </div>
            </div>
        </form>
    </div>

    @* Table Section *@
    <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0 text-center">
                <thead class="table-light text-uppercase small fw-bold">
                    <tr>
                        <th class="py-3 text-start ps-4">Department Name</th>
                        <th class="py-3">Faculty / University</th>
                        <th class="py-3 text-primary"><i class="bi bi-graph-up-arrow me-1"></i> Rate</th>
                        <th class="py-3 text-success"><i class="bi bi-cash-stack me-1"></i> Price</th>
                        <th class="py-3 text-warning"><i class="bi bi-clock-history me-1"></i> Hours</th>
                        <th class="py-3">Actions</th>
                    </tr>
                </thead>
                <tbody class="border-top-0">
                    @if (Model.Count == 0)
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">
                                <i class="bi bi-folder-x fs-1 d-block mb-2"></i> No departments found.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-bold py-3 text-start ps-4">
                                    <a asp-action="Details" asp-route-id="@item.Department_ID" class="text-decoration-none text-dark hover-primary">
                                        @item.DepartmentName
                                    </a>
                                </td>
                                <td>
                                    @* عرض الكلية والجامعة مع باج لنوع الجامعة *@
                                    <div class="d-flex flex-column align-items-center">
                                        <span class="small fw-bold">@item.Faculty?.Name</span>
                                        <span class="text-muted smaller">@item.Faculty?.University?.Name</span>
                                        @if (item.Faculty?.University?.Type == UniversityType.Governmental)
                                        {
                                            <span class="badge bg-info text-dark smaller" style="font-size: 0.65rem;">Public</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-light text-muted border smaller" style="font-size: 0.65rem;">Private</span>
                                        }
                                    </div>
                                </td>
                                <td>
                                    <span class="fw-bold text-primary">@item.AcceptanceRate%</span>
                                </td>
                                <td>
                                    <span class="fw-bold text-success">@item.HourPrice <small class="text-muted fw-normal">JOD</small></span>
                                </td>
                                <td>
                                    <span class="fw-bold text-warning">@item.TotalCreditHours <small class="text-muted fw-normal">Hrs</small></span>
                                </td>
                                <td>
                                    <div class="dropdown">
                                        <button class="btn btn-sm btn-light border dropdown-toggle rounded-pill px-3" type="button" data-bs-toggle="dropdown">
                                            Manage
                                        </button>
                                        <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0 rounded-3">
                                            <li><a class="dropdown-item py-2" asp-action="Details" asp-route-id="@item.Department_ID"><i class="bi bi-eye text-info me-2"></i> Details</a></li>
                                            <li><a class="dropdown-item py-2" asp-action="Edit" asp-route-id="@item.Department_ID"><i class="bi bi-pencil text-warning me-2"></i> Edit</a></li>
                                            <li><hr class="dropdown-divider"></li>
                                            <li><a class="dropdown-item py-2 text-danger" asp-action="Delete" asp-route-id="@item.Department_ID"><i class="bi bi-trash me-2"></i> Delete</a></li>
                                        </ul>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    @* Pagination Section *@
    @if (Model.TotalPages > 1)
    {
        <div class="d-flex justify-content-center align-items-center gap-3 mt-4">
            <a asp-action="Index"
               asp-route-pageNumber="@(Model.PageIndex - 1)"
               asp-route-currentFilter="@ViewData["CurrentFilter"]"
               asp-route-minRate="@ViewData["MinRate"]"
               asp-route-maxPrice="@ViewData["MaxPrice"]"
               asp-route-uniType="@ViewData["SelectedUniType"]"
               class="btn btn-white shadow-sm border @(Model.HasPreviousPage ? "" : "disabled text-muted")">
                <i class="bi bi-chevron-left"></i> Previous
            </a>

            <span class="fw-bold text-muted small">
                Page @Model.PageIndex of @Model.TotalPages
            </span>

            <a asp-action="Index"
               asp-route-pageNumber="@(Model.PageIndex + 1)"
               asp-route-currentFilter="@ViewData["CurrentFilter"]"
               asp-route-minRate="@ViewData["MinRate"]"
               asp-route-maxPrice="@ViewData["MaxPrice"]"
               asp-route-uniType="@ViewData["SelectedUniType"]"
               class="btn btn-white shadow-sm border @(Model.HasNextPage ? "" : "disabled text-muted")">
                Next <i class="bi bi-chevron-right"></i>
            </a>
        </div>
    }

</div>

@section Scripts {
    <style>
        .hover-primary:hover {
            color: #0d6efd !important;
        }

        .dropdown-item:hover {
            background-color: #f8f9fa;
        }

        .smaller {
            font-size: 0.75rem;
        }

        .table th, .table td {
            vertical-align: middle;
            white-space: nowrap;
        }
    </style>
}