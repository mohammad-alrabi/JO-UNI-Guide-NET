@model JO_UNI_Guide.Models.Department
@{
    ViewData["Title"] = "Delete Department";
    Layout = "_AdminLayout";
}

<h2 class="page-title">Delete Department</h2>

<div class="delete-card">
    <h4>Are you sure you want to delete this department?</h4>
    <div class="mb-3">
        <strong>Department Name:</strong> @Model.DepartmentName
    </div>
    <div class="mb-3">
        <strong>Faculty:</strong> @Model.Faculty?.Name
    </div>
    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="Department_ID" />
        <button type="submit" class="btn btn-danger">Confirm Delete</button>
        <a asp-action="Index" class="btn">Back</a>
    </form>
</div>