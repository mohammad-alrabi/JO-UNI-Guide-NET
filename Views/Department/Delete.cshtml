@model JO_UNI_Guide.Models.Department
@{
    ViewData["Title"] = "Delete Department";
    Layout = "_AdminLayout";
}

<h2 class="page-title text-danger">Delete Department</h2>

<div class="card border-0 shadow-sm rounded-4 overflow-hidden">
    <div class="card-header bg-danger text-white py-3">
        <h5 class="mb-0"><i class="bi bi-exclamation-octagon me-2"></i> Danger Zone: Action Required</h5>
    </div>

    <div class="card-body p-4">
        <div class="alert alert-warning border-0 shadow-sm mb-4">
            <h4 class="alert-heading fw-bold">Are you sure?</h4>
            <p class="mb-0">You are about to delete <strong>@Model.DepartmentName</strong>. This action will also remove all courses associated with this department. This cannot be undone.</p>
        </div>

        <div class="row g-3">
            <div class="col-md-6">
                <div class="p-3 border rounded-3 bg-light">
                    <small class="text-uppercase fw-bold text-muted d-block mb-1">Department Name</small>
                    <span class="fs-5 fw-bold text-dark">@Model.DepartmentName</span>
                </div>
            </div>
            <div class="col-md-6">
                <div class="p-3 border rounded-3 bg-light">
                    <small class="text-uppercase fw-bold text-muted d-block mb-1">Parent Faculty</small>
                    <span class="fs-5">@Model.Faculty?.Name</span>
                </div>
            </div>

            <div class="col-md-6">
                <div class="p-3 border rounded-3 bg-light border-start border-primary border-4">
                    <small class="text-uppercase fw-bold text-muted d-block mb-1">Admission Rate</small>
                    <span class="fs-5 fw-bold text-primary">@Model.AcceptanceRate%</span>
                </div>
            </div>
            <div class="col-md-6">
                <div class="p-3 border rounded-3 bg-light border-start border-success border-4">
                    <small class="text-uppercase fw-bold text-muted d-block mb-1">Price Per Hour</small>
                    <span class="fs-5 fw-bold text-success">@Model.HourPrice JOD</span>
                </div>
            </div>
        </div>

        <div class="mt-5 pt-3 border-top">
            <form asp-action="Delete" method="post" class="d-flex gap-2">
                <input type="hidden" asp-for="Department_ID" />
                <button type="submit" class="btn btn-danger px-4 py-2 shadow-sm fw-bold">
                    <i class="bi bi-trash3 me-1"></i> Confirm Permanent Delete
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary px-4 py-2">
                    Cancel and Go Back
                </a>
            </form>
        </div>
    </div>
</div>