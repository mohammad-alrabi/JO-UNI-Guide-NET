@model LoginViewModel
@{
    Layout = "_LoginLayout";
    // التحقق إذا كان الداخل من طرف الإدارة
    var isManagement = ViewBag.Role == "Admin" || ViewBag.Role == "SuperAdmin";
    ViewData["Title"] = isManagement ? "Management Login" : "Student Login";

    // تحديد الأكشن (الميثود) التي سيذهب إليها الفورم
    var targetAction = isManagement ? "LoginAdmin" : "LoginSt";
}

<div class="login-container">
    <div class="login-horizontal-card shadow-lg border-0">
        <div class="row g-0 h-100">
            @* الجزء الجانبي (البراندينج) - الستايل كما هو *@
            <div class="col-md-5 login-branding d-none d-md-flex flex-column align-items-center justify-content-center text-white p-5">
                <img src="~/images/joUniGuideLogo-removebg-preview.png" alt="Logo" class="login-side-logo mb-4">
                <h3 class="fw-bold">JO-UNI-Guide</h3>
                <p class="text-center opacity-75 small">
                    @(isManagement ? "Control Tower - Administration Only" : "Your Gateway to Academic Success in Jordan")
                </p>
            </div>

            @* الجزء الخاص بالفورم *@
            <div class="col-md-7 bg-white p-5 d-flex flex-column justify-content-center">
                <div class="form-header mb-4">
                    <h2 class="fw-bold text-dark">@(isManagement ? "Admin Login" : "Sign In Student")</h2>
                    <p class="text-muted small">
                        @(isManagement ? "Enter secure credentials to manage the system." : "Enter your details to access your student dashboard.")
                    </p>
                </div>

                @* التعديل هنا: نستخدم targetAction للتوجه للميثود الصح *@
                <form asp-action="@targetAction" asp-controller="Account" method="post">
                    @Html.AntiForgeryToken()

                    @* نرسل الـ Role مخفي عشان يضل الكنترولر عارف إحنا وين في حال فشل الدخول *@
                    <input type="hidden" name="role" value="@ViewBag.Role" />

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small border-0"></div>

                    <div class="mb-4">
                        <label asp-for="Email" class="form-label fw-bold text-secondary small">EMAIL ADDRESS</label>
                        <div class="custom-input-group">
                            <i class="bi bi-envelope icon"></i>
                            <input asp-for="Email" class="form-control" placeholder="@(isManagement ? "admin@jouni.com" : "student@example.com")" />
                        </div>
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Password" class="form-label fw-bold text-secondary small">PASSWORD</label>
                        <div class="custom-input-group">
                            <i class="bi bi-lock icon"></i>
                            <input asp-for="Password" type="password" class="form-control" placeholder="••••••••" />
                        </div>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div class="form-check">
                            <input asp-for="RememberMe" class="form-check-input" type="checkbox" />
                            <label asp-for="RememberMe" class="form-check-label small text-muted">Keep me signed in</label>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-login-modern w-100 shadow-sm py-3 fw-bold">
                        @(isManagement ? "LOGIN TO PANEL" : "SIGN IN")
                    </button>
                </form>

                <div class="text-center mt-5">
                    @* كبسة الـ Register تظهر فقط للطالب *@
                    @if (!isManagement)
                    {
                        <p class="small text-muted mb-3">
                            Don't have an account?
                            <a asp-action="Register" class="text-brand fw-bold text-decoration-none ms-1">Create Account</a>
                        </p>
                    }

                    <a href="/" class="text-decoration-none text-muted small hover-primary">
                        <i class="bi bi-arrow-left me-1"></i> Return to Homepage
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>