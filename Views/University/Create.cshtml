@model JO_UNI_Guide.Models.University

@{
    ViewData["Title"] = "Create University";
    Layout = "_AdminLayout"; 
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="form-card shadow-sm">
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4 border-bottom pb-3">
                    <div>
                        <h2 class="page-title mb-1"><i class="bi bi-plus-circle-fill text-primary me-2"></i>Create University</h2>
                        <p class="text-muted mb-0">Add a new university with logo and ranking details.</p>
                    </div>

                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left me-1"></i> Back
                    </a>
                </div>

                <form asp-action="Create" method="post" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3 rounded-3"></div>

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-bold"></label>
                        <input asp-for="Name" class="form-control custom-input" placeholder="Enter university name" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Location" class="form-label fw-bold"></label>
                        <input asp-for="Location" class="form-control custom-input" placeholder="Enter university location" />
                        <span asp-validation-for="Location" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Rank_QS" class="form-label fw-bold"></label>
                        <input asp-for="Rank_QS" class="form-control custom-input" placeholder="Enter QS rank" />
                        <span asp-validation-for="Rank_QS" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold">University Logo</label>
                        <input type="file"
                               name="logoFile"
                               class="form-control custom-input"
                               accept="image/*"
                               onchange="previewImage(event)" />
                    </div>

                    <div class="image-preview text-center mb-4 bg-light p-3 rounded-3 border">
                        <p class="text-muted small mb-2">Logo Preview</p>
                        <img id="imagePreview"
                             src="/images/default.png"
                             alt="Preview"
                             class="img-fluid shadow-sm"
                             style="max-height: 150px; object-fit: contain;" />
                    </div>

                    <div class="d-flex gap-2 flex-wrap">
                        <button type="submit" class="btn btn-main flex-grow-1 fw-bold">
                            <i class="bi bi-save me-1"></i> Save University
                        </button>

                        <a asp-action="Index" class="btn btn-light border px-4 fw-bold">
                            Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // كود المعاينة تبعك ممتاز جداً وما غيرت فيه إشي
        function previewImage(event) {
            const file = event.target.files[0];
            if (!file) return;
            const reader = new FileReader();
            reader.onload = function () {
                document.getElementById('imagePreview').src = reader.result;
            };
            reader.readAsDataURL(file);
        }
    </script>
}