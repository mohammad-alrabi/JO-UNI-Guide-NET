@model JO_UNI_Guide.Helpers.PaginatedList<JO_UNI_Guide.Models.University>

<div class="container mt-5">

    <h2 class="section-title">Universities</h2>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success text-center">
            @TempData["Success"]
        </div>
    }

    <form method="get" class="d-flex mb-4">
        <input class="form-control login-input me-2"
               type="text"
               name="searchString"
               value="@ViewData["CurrentFilter"]"
               placeholder="Search..." />
        <button class="btn btn-primary btn-login">Search</button>
    </form>

    <a href="/University/Create" class="btn btn-success mb-3">+ Add University</a>

    <table class="table table-bordered table-hover text-center shadow-sm">
        <thead class="table-dark">
            <tr>
                <th>Name</th>
                <th>Logo</th>
                <th>Location</th>
                <th>Rank</th>
                <th>Actions</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Name</td>
                    <td>
                        <img src="@item.Logo" width="60" class="img-thumbnail" />
                    </td>
                    <td>@item.Location</td>
                    <td>@item.Rank_QS</td>
                    <td>
                        <a class="btn btn-warning btn-sm" href="/University/Edit/@item.University_ID">Edit</a>
                        <a class="btn btn-info btn-sm" href="/University/Details/@item.University_ID">Details</a>
                        <a class="btn btn-danger btn-sm" href="/University/Delete/@item.University_ID">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="d-flex justify-content-between mt-3">
        <a class="btn btn-secondary" href="/University?pageNumber=@(Model.PageIndex - 1)">Previous</a>
        <a class="btn btn-secondary" href="/University?pageNumber=@(Model.PageIndex + 1)">Next</a>
    </div>

</div>