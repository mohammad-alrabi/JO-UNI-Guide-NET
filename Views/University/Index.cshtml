@model JO_UNI_Guide.Helpers.PaginatedList<JO_UNI_Guide.Models.University>

@{
    ViewData["Title"] = "Universities";
    Layout = "_AdminLayout";
}

<div class="container py-4">

    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
        <div>
            <h2 class="page-title mb-1">Universities</h2>
            <p class="text-muted mb-0">Manage universities easily</p>
        </div>

        <a asp-action="Create" class="btn btn-main">
            Add University
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
            @TempData["Success"]
        </div>
    }

    <div class="mb-4">
        <form asp-action="Index" method="get">
            <div class="row g-2">
                <div class="col-md-9">
                    <input type="text"
                           name="searchString"
                           value="@ViewData["CurrentFilter"]"
                           class="form-control"
                           placeholder="Search..." />
                </div>
                <div class="col-md-3 d-flex gap-2">
                    <button class="btn btn-dark w-100">Search</button>
                    <a asp-action="Index" class="btn btn-outline-secondary w-100">Reset</a>
                </div>
            </div>
        </form>
    </div>

    @if (Model.Count == 0)
    {
        <div class="alert alert-info text-center">
            No universities found.
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var item in Model)
            {
                <div class="col-lg-4 col-md-6 mb-4">
                    <div class="card uni-admin-card h-100">

                        <img src="@item.Logo"
                             onerror="this.src='/images/default.png'"
                             class="card-img-top" />

                        <div class="p-3">
                            <h5>@item.Name</h5>
                            <p>@item.Location</p>
                            <div>QS Rank: @item.Rank_QS</div>

                            <div class="d-flex gap-2 mt-3 flex-wrap">
                                <a asp-action="Details" asp-route-id="@item.University_ID" class="btn btn-info btn-sm text-white">
                                    Details
                                </a>

                                <a asp-action="Edit" asp-route-id="@item.University_ID" class="btn btn-warning btn-sm">
                                    Edit
                                </a>

                                <a asp-action="Delete" asp-route-id="@item.University_ID" class="btn btn-danger btn-sm">
                                    Delete
                                </a>
                            </div>
                        </div>

                    </div>
                </div>
            }
        </div>

        <div class="d-flex justify-content-center gap-2 mt-4">
            @if (Model.HasPreviousPage)
            {
                <a asp-action="Index"
                   asp-route-pageNumber="@(Model.PageIndex - 1)"
                   asp-route-currentFilter="@ViewData["CurrentFilter"]"
                   class="btn btn-outline-primary">
                    Previous
                </a>
            }

            <span class="btn btn-light disabled">
                Page @Model.PageIndex
            </span>

            @if (Model.HasNextPage)
            {
                <a asp-action="Index"
                   asp-route-pageNumber="@(Model.PageIndex + 1)"
                   asp-route-currentFilter="@ViewData["CurrentFilter"]"
                   class="btn btn-outline-primary">
                    Next
                </a>
            }
        </div>
    }

</div>