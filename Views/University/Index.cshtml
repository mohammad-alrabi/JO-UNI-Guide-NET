@{
    ViewData["Title"] = "Universities";
    Layout = "_AdminLayout";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
        <div>
            <h2 class="page-title mb-1">Universities</h2>
            <p class="text-muted mb-0">Manage universities, search quickly, and explore details.</p>
        </div>

        <a asp-action="Create" class="btn btn-main">
            <i class="bi bi-plus-circle me-1"></i> Add University
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mb-4 shadow-sm" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="search-box mb-4">
        <form asp-action="Index" method="get">
            <div class="row g-2 align-items-center">
                <div class="col-md-9 position-relative">
                    <i class="bi bi-search position-absolute top-50 start-0 translate-middle-y ms-3 text-muted"></i>
                    <input type="text"
                           name="searchString"
                           value="@ViewData["CurrentFilter"]"
                           class="form-control search-input ps-5"
                           placeholder="Search by university name or location..." />
                </div>
                <div class="col-md-3 d-flex gap-2">
                    <button type="submit" class="btn btn-dark w-100">Search</button>
                    <a asp-action="Index" class="btn btn-outline-secondary w-100">Reset</a>
                </div>
            </div>
        </form>
    </div>

    @if (Model.Count == 0)
    {
        <div class="alert alert-info text-center py-4">
            <i class="bi bi-search fs-2 mb-2 d-block"></i>
            No universities found.
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var item in Model)
            {
                <div class="col-lg-4 col-md-6 mb-4">
                    <div class="card uni-admin-card h-100 border-0">
                        <img src="@item.Logo"
                             alt="@item.Name"
                             class="card-img-top"
                             onerror="this.src='/images/default.png'" />

                        <div class="uni-admin-body">
                            <h5 class="uni-admin-name mb-2">@item.Name</h5>
                            <p class="uni-admin-location mb-2">@item.Location</p>
                            <div class="uni-rank mb-3">QS Rank: @item.Rank_QS</div>

                            <div class="d-flex justify-content-center flex-wrap gap-2">
                                <a asp-action="Details" asp-route-id="@item.University_ID" class="btn btn-info btn-sm px-3 text-white">
                                    <i class="bi bi-eye"></i> Details
                                </a>

                                <a asp-action="Edit" asp-route-id="@item.University_ID" class="btn btn-warning btn-sm px-3 text-white">
                                    <i class="bi bi-pencil-square"></i> Edit
                                </a>

                                <a asp-action="Delete" asp-route-id="@item.University_ID" class="btn btn-danger btn-sm px-3">
                                    <i class="bi bi-trash"></i> Delete
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="d-flex justify-content-center align-items-center gap-2 mt-4 flex-wrap pagination-clean">
            @if (Model.HasPreviousPage)
            {
                <a asp-action="Index"
                   asp-route-pageNumber="@(Model.PageIndex - 1)"
                   asp-route-currentFilter="@ViewData["CurrentFilter"]"
                   class="btn btn-outline-primary">
                    <i class="bi bi-chevron-left"></i> Previous
                </a>
            }

            <span class="btn btn-light disabled">
                Page @Model.PageIndex
            </span>

            @if (Model.HasNextPage)
            {
                <a asp-action="Index"
                   asp-route-pageNumber="@(Model.PageIndex + 1)"
                   asp-route-currentFilter="@ViewData["CurrentFilter"]"
                   class="btn btn-outline-primary">
                    Next <i class="bi bi-chevron-right"></i>
                </a>
            }
        </div>
    }
