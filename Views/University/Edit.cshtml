@model JO_UNI_Guide.Models.University

@{
    ViewData["Title"] = "Edit University";
    Layout = "_AdminLayout";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="form-card shadow-sm border-0">

                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4 border-bottom pb-3">
                    <div>
                        <h2 class="page-title mb-1">Edit University</h2>
                        <p class="text-muted mb-0">Update details for <strong>@Model.Name</strong></p>
                    </div>

                    <a asp-action="Index" class="btn btn-outline-secondary">
                        Back
                    </a>
                </div>

                <form asp-action="Edit" method="post" enctype="multipart/form-data">

                    <input type="hidden" asp-for="University_ID" />
                    <input type="hidden" asp-for="Logo" />

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label"></label>
                        <input asp-for="Name" class="form-control custom-input" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Location" class="form-label"></label>
                        <input asp-for="Location" class="form-control custom-input" />
                        <span asp-validation-for="Location" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Rank_QS" class="form-label"></label>
                        <input asp-for="Rank_QS" class="form-control custom-input" />
                        <span asp-validation-for="Rank_QS" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Type" class="form-label fw-bold">University Type</label>
                        <select asp-for="Type" class="form-select shadow-sm"
                                asp-items="Html.GetEnumSelectList<UniversityType>()">
                            <option value="">-- Select Type --</option>
                        </select>
                        <span asp-validation-for="Type" class="text-danger small"></span>
                    </div>
                    @* حقل الوصف *@
                    <div class="mb-3">
                        <label asp-for="Description" class="form-label fw-bold">University Description</label>
                        <textarea asp-for="Description" class="form-control" rows="4" placeholder="Write about the university..."></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="row">
                        @* حقل الموقع الإلكتروني *@
                        <div class="col-md-6 mb-3">
                            <label asp-for="WebsiteUrl" class="form-label fw-bold">Website URL</label>
                            <input asp-for="WebsiteUrl" class="form-control" placeholder="https://example.edu.jo" />
                            <span asp-validation-for="WebsiteUrl" class="text-danger"></span>
                        </div>

                        @* حقل الإيميل *@
                        <div class="col-md-6 mb-3">
                            <label asp-for="Email" class="form-label fw-bold">Official Email</label>
                            <input asp-for="Email" type="email" class="form-control" placeholder="info@university.edu.jo" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>
                    </div>

                    @* حقل رقم الهاتف *@
                    <div class="mb-3 col-md-6">
                        <label asp-for="ContactPhone" class="form-label fw-bold">Contact Phone</label>
                        <input asp-for="ContactPhone" class="form-control" placeholder="+962 6 XXXXXXX" />
                        <span asp-validation-for="ContactPhone" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label>Change Logo (Optional)</label>
                        <input type="file"
                               name="logoFile"
                               class="form-control"
                               onchange="previewImage(event)" />
                    </div>

                    <div class="text-center mb-3">
                        <img id="imagePreview"
                             src="@Model.Logo"
                             style="max-height:150px;"
                             onerror="this.src='/images/default.png'" />
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary flex-grow-1">
                            Update
                        </button>

                        <a asp-action="Index" class="btn btn-secondary">
                            Cancel
                        </a>
                    </div>

                </form>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function previewImage(event) {
            const reader = new FileReader();
            reader.onload = function () {
                document.getElementById('imagePreview').src = reader.result;
            };
            reader.readAsDataURL(event.target.files[0]);
        }
    </script>
}