@model JO_UNI_Guide.Models.University

@{
    ViewData["Title"] = "Delete University";
    Layout = "_AdminLayout";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="delete-card shadow-sm border border-danger border-opacity-25">

                <div class="text-center mb-4">
                    <h2 class="page-title text-danger">
                        Delete University
                    </h2>
                    <p class="text-muted">Are you sure you want to delete this university?</p>
                </div>

                <div class="alert alert-danger text-center fw-bold mb-4">
                    This action cannot be undone!
                </div>

                <div class="text-center mb-4">
                    <img src="@Model.Logo"
                         class="img-fluid shadow-sm p-1 bg-white border"
                         style="max-width: 120px; border-radius: 15px;"
                         onerror="this.src='/images/default.png'" />
                </div>

                <div class="text-center mb-4">
                    <h4 class="fw-bold">@Model.Name</h4>
                    <p class="text-muted">@Model.Location</p>
                    <span class="badge bg-primary">
                        QS Rank: @Model.Rank_QS
                    </span>
                </div>

                <form asp-action="Delete" method="post">
                    <input type="hidden" asp-for="University_ID" />

                    <div class="d-flex justify-content-center gap-3">
                        <button type="submit" class="btn btn-danger fw-bold">
                            Confirm Delete
                        </button>

                        <a asp-action="Index" class="btn btn-secondary">
                            Cancel
                        </a>
                    </div>
                </form>

            </div>
        </div>
    </div>
</div>