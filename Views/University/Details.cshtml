@model JO_UNI_Guide.Models.University

@{
    ViewData["Title"] = "University Details";
    Layout = "_AdminLayout";
}

<div class="container py-4">

    <div class="details-card">

        <!-- Header -->
        <div class="details-header d-flex align-items-center gap-4 flex-wrap">

            <div class="logo-box">
                <img src="@Model.Logo"
                     onerror="this.src='/images/default.png'"
                     alt="@Model.Name" />
            </div>

            <div class="flex-grow-1">
                <h2 class="page-title mb-2">@Model.Name</h2>

                <p class="text-muted mb-1">
                    📍 @Model.Location
                </p>

                <span class="uni-rank">QS Rank: #@Model.Rank_QS</span>
            </div>

            <div class="d-flex gap-2">
                <a asp-action="Edit"
                   asp-route-id="@Model.University_ID"
                   class="btn btn-warning">
                    Edit
                </a>

                <a asp-action="Index"
                   class="btn btn-outline-secondary">
                    Back
                </a>
            </div>

        </div>

        <hr class="my-4" />

        <!-- Faculties Section -->
        <div class="faculties-section">

            <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
                <h4 class="fw-bold mb-0">Faculties</h4>

                <span class="badge-count">
                    @(Model.Faculties?.Count() ?? 0) Faculties
                </span>
            </div>

            @if (Model.Faculties != null && Model.Faculties.Any())
            {
                <div class="faculties-grid">
                    @foreach (var faculty in Model.Faculties)
                    {
                        <div class="faculty-box">
                            <a asp-controller="Faculty" asp-action="Details" asp-route-id="@faculty.Faculty_ID" class="text-decoration-none text-dark d-block">
                                <i class="bi bi-arrow-right-circle me-2 text-primary"></i> @faculty.Name
                            </a>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="alert alert-info text-center mb-0">
                    No faculties found for this university.
                </div>
            }

        </div>

    </div>

</div>