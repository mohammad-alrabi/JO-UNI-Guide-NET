@model JO_UNI_Guide.Models.University

@{
    ViewData["Title"] = "University Details";
}

<div class="container py-4">

    <div class="details-card">
        <div class="p-4 p-md-5">

            <div class="row align-items-center g-4">

                <!-- Logo -->
                <div class="col-md-3 text-center">
                    <img src="@Model.Logo"
                         onerror="this.src='/images/default.png'"
                         alt="@Model.Name"
                         class="details-logo img-fluid shadow-sm" />
                </div>

                <!-- Info -->
                <div class="col-md-9">
                    <h2 class="page-title mb-3">@Model.Name</h2>

                    <p class="text-muted mb-2">
                        Location: @Model.Location
                    </p>

                    <div class="mb-3">
                        <span class="uni-rank">QS Rank: #@Model.Rank_QS</span>
                    </div>

                    <div class="d-flex gap-2 flex-wrap">
                        <a asp-action="Edit"
                           asp-route-id="@Model.University_ID"
                           class="btn btn-warning">
                            Edit
                        </a>

                        <a asp-action="Index"
                           class="btn btn-outline-secondary">
                            Back
                        </a>
                    </div>
                </div>

            </div>

            <hr class="my-4" />

            <!-- Faculties -->
            <div>
                <h4 class="mb-3 fw-bold">Faculties</h4>

                @if (Model.Faculties != null && Model.Faculties.Any())
                {
                    <div class="row">
                        @foreach (var faculty in Model.Faculties)
                        {
                            <div class="col-md-6 mb-3">
                                <div class="faculty-box">
                                    @faculty.Name
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="alert alert-info text-center mb-0">
                        No faculties found for this university.
                    </div>
                }
            </div>

        </div>
    </div>

</div>