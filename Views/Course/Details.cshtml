@model JO_UNI_Guide.Models.Course

@{
    ViewData["Title"] = "Course Details";
    Layout = "_AdminLayout";
}

<div class="container py-4">

    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div>
            <h2 class="page-title mb-1">Course Profile</h2>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0 small">
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Courses</a></li>
                    <li class="breadcrumb-item active text-muted" aria-current="page">@Model.Course_Name</li>
                </ol>
            </nav>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary px-4 shadow-sm rounded-pill">
            <i class="bi bi-arrow-left me-2"></i> Back to List
        </a>
    </div>

    <div class="row g-4">
        <div class="col-lg-4">
            <div class="card shadow-sm border-0 rounded-4 p-4 h-100 text-center bg-white">

                <div class="bg-primary bg-opacity-10 text-primary rounded-circle mx-auto d-flex align-items-center justify-content-center mb-4" style="width: 100px; height: 100px;">
                    <i class="bi bi-journal-bookmark-fill fs-1"></i>
                </div>

                <h4 class="fw-bold text-dark mb-4">@Model.Course_Name</h4>
            </div>
        </div>

        <div class="col-lg-8">

            <div class="card shadow-sm border-0 rounded-4 p-4 mb-4 bg-white">
                <h5 class="fw-bold text-secondary border-bottom pb-3 mb-4">
                    <i class="bi bi-diagram-3 me-2 text-primary"></i> Academic Hierarchy
                </h5>

                <div class="row g-3">
                    <div class="col-md-4">
                        <div class="p-3 bg-light rounded-3 border h-100 text-center" style="transition: 0.3s;" onmouseover="this.classList.add('shadow-sm')" onmouseout="this.classList.remove('shadow-sm')">
                            <i class="bi bi-building fs-3 text-secondary mb-2 d-block"></i>
                            <span class="d-block text-muted small fw-bold mb-1">University</span>
                            <span class="fw-bold text-dark">@(Model.Department?.Faculty?.University?.Name ?? "N/A")</span>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="p-3 bg-light rounded-3 border h-100 text-center" style="transition: 0.3s;" onmouseover="this.classList.add('shadow-sm')" onmouseout="this.classList.remove('shadow-sm')">
                            <i class="bi bi-mortarboard fs-3 text-success mb-2 d-block"></i>
                            <span class="d-block text-muted small fw-bold mb-1">Faculty</span>
                            <span class="fw-bold text-dark">@(Model.Department?.Faculty?.Name ?? "N/A")</span>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="p-3 bg-light rounded-3 border h-100 text-center" style="transition: 0.3s;" onmouseover="this.classList.add('shadow-sm')" onmouseout="this.classList.remove('shadow-sm')">
                            <i class="bi bi-tags fs-3 text-primary mb-2 d-block"></i>
                            <span class="d-block text-muted small fw-bold mb-1">Department</span>
                            <span class="fw-bold text-dark">@(Model.Department?.DepartmentName ?? "N/A")</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm border-0 rounded-4 p-4 bg-white">
                <h5 class="fw-bold text-secondary border-bottom pb-3 mb-4">
                    <i class="bi bi-info-circle me-2 text-info"></i> Course Description
                </h5>
                <div class="p-4 bg-light rounded-3 border">
                    <p class="mb-0 text-dark" style="line-height: 1.8; font-size: 1.05rem;">
                        @(string.IsNullOrEmpty(Model.Details) ? "No description provided for this course yet." : Model.Details)
                    </p>
                </div>
            </div>

        </div>
    </div>
</div>