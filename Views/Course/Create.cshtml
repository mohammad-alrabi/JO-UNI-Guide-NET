@model JO_UNI_Guide.Models.Course
@{
    ViewData["Title"] = "Create Course";
}

<h1>Create Course</h1>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        @TempData["Success"]
    </div>
}

<form asp-action="Create" method="post">
    <div>
        <label asp-for="Course_Name"></label>
        <input asp-for="Course_Name" class="form-control" />
        <span asp-validation-for="Course_Name" class="text-danger"></span>
    </div>

    <div>
        <label asp-for="Details"></label>
        <textarea asp-for="Details" class="form-control"></textarea>
        <span asp-validation-for="Details" class="text-danger"></span>
    </div>

    <div>
        <label asp-for="Department_ID"></label>
        <select asp-for="Department_ID" asp-items="@(ViewData["Department_ID"] as SelectList)" class="form-control"></select>
        <span asp-validation-for="Department_ID" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-success">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}