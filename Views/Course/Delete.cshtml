@model JO_UNI_Guide.Models.Course
@{
    ViewData["Title"] = "Delete Course";
}

<h1>Are you sure you want to delete this course?</h1>

<p><strong>Name:</strong> @Model.Course_Name</p>
<p><strong>Department:</strong> @Model.Department.DepartmentName</p>

<form asp-action="DeleteConfirmed" method="post">
    <input type="hidden" asp-for="Course_ID" />
    <button type="submit" class="btn btn-danger">Yes, Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>