@model List<JO_UNI_Guide.Models.Course>

<h1 style="margin-bottom:20px;">🎯 Recommended Majors for You</h1>

<form method="get" class="filters">

    <select name="type">
        <option value="">All</option>
        <option value="gov">Government</option>
        <option value="private">Private</option>
    </select>

    <select name="sort">
        <option value="">Sort By</option>
        <option value="gpa">GPA</option>
        <option value="name">Name</option>
    </select>

    <button type="submit">Apply</button>
</form>

@{
    string GetMatch(int gpa)
    {
        if (gpa >= 85) return "Strong Match";
        if (gpa >= 75) return "Match";
        return "Weak Match";
    }

    string GetTagClass(int gpa)
    {
        if (gpa >= 85) return "strong";
        if (gpa >= 75) return "match";
        return "weak";
    }
}

<div class="cards-container">

@foreach (var item in Model)
{
    @{
        int fakeGpa = 80;
    }

    <div class="card">

        <h3>@item.Course_Name</h3>

        <p>@item.Department.Faculty.University.Name</p>

        <span class="gpa">GPA: @fakeGpa%</span>

        <span class="tag @GetTagClass(fakeGpa)">
            @GetMatch(fakeGpa)
        </span>

        <span class="badge">Recommended for you</span>

    </div>
}

</div>