@model JO_UNI_Guide.Helpers.PaginatedList<JO_UNI_Guide.Models.Course>
@{
    ViewData["Title"] = "Courses List";
    Layout = "_AdminLayout";
    var currentFilter = ViewData["CurrentFilter"] as string;
}

<h2 class="page-title">Courses</h2>

<div class="uni-admin-card">

    <div class="top-bar">
        <form asp-action="Index" method="get" class="search-form">
            <input type="text"
                   name="searchString"
                   value="@currentFilter"
                   placeholder="Search courses..."
                   class="form-control" />

            <button type="submit" class="btn btn-main">Search</button>
        </form>

        <a asp-action="Create" class="btn btn-main add-btn">
            Add New Course
        </a>
    </div>

    <table>
        <thead>
            <tr>
                <th>Name</th>
                <th>Department</th>
                <th>Faculty</th>
                <th>University</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Course_Name</td>
                    <td>@item.Department.DepartmentName</td>
                    <td>@item.Department.Faculty.Name</td>
                    <td>@item.Department.Faculty.University.Name</td>
                    <td>
                        <div class="btn-group">
                            <a asp-action="Details" asp-route-id="@item.Course_ID" class="btn btn-info btn-sm">Details</a>
                            <a asp-action="Edit" asp-route-id="@item.Course_ID" class="btn btn-warning btn-sm">Edit</a>
                            <a asp-action="Delete" asp-route-id="@item.Course_ID" class="btn btn-danger btn-sm">Delete</a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="btn-group" style="margin-top:1.5rem;">
        <span>Page @Model.PageIndex of @Model.TotalPages</span>
        @if (Model.HasPreviousPage)
        {
            <a asp-action="Index" asp-route-pageNumber="@(Model.PageIndex - 1)" class="btn btn-main">Previous</a>
        }
        @if (Model.HasNextPage)
        {
            <a asp-action="Index" asp-route-pageNumber="@(Model.PageIndex + 1)" class="btn btn-main">Next</a>
        }
    </div>
</div>