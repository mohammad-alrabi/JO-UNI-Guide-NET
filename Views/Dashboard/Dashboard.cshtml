@model DashboardViewModel
@{
    ViewData["Title"] = "Control Panel";
    Layout = "_AdminLayout";
}

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">

<div class="container-fluid px-4 mt-4" style="font-family: 'Poppins', sans-serif;">

    @* Header Section *@
    <div class="d-flex justify-content-between align-items-center mb-5 pb-3 border-bottom">
        <div>
            <h2 class="fw-bold text-dark m-0">Welcome to Dashboard Page</h2>
        </div>
        <div class="text-muted">
            <i class="bi bi-calendar3 me-2"></i> @DateTime.Now.ToString("D")
        </div>
    </div>

    @* Stats Cards Row *@
    <div class="row g-4 mb-5">

        @* Universities - الحكومية والخاصة بلمحة *@
        <div class="col-xl-3 col-md-6">
            <div class="stat-card bg-white h-100 shadow-sm rounded-4 p-4 border-0 position-relative overflow-hidden">
                <div class="stat-icon bg-light-primary text-primary">
                    <i class="bi bi-bank"></i>
                </div>
                <div class="stat-content mt-3">
                    <h6 class="text-uppercase text-muted fw-bold mb-1 small tracking-wider">Total Universities</h6>
                    <h2 class="fw-bold text-dark mb-3">@Model.UniversitiesCount</h2>
                    <div class="d-flex gap-3 pt-2 border-top">
                        <span class="text-primary small fw-bold">
                            <i class="bi bi-flag-fill me-1"></i> Public: @Model.PublicUniversitiesCount
                        </span>
                        <span class="text-secondary small fw-bold">
                            <i class="bi bi-building me-1"></i> Private: @Model.PrivateUniversitiesCount
                        </span>
                    </div>
                </div>
                @* شكل ديكوري خلفي *@
                <i class="bi bi-bank decorative-icon"></i>
            </div>
        </div>

        @* Faculties *@
        <div class="col-xl-3 col-md-6">
            <div class="stat-card bg-white h-100 shadow-sm rounded-4 p-4 border-0 position-relative overflow-hidden">
                <div class="stat-icon bg-light-success text-success">
                    <i class="bi bi-mortarboard"></i>
                </div>
                <div class="stat-content mt-3">
                    <h6 class="text-uppercase text-muted fw-bold mb-1 small tracking-wider">Total Faculties</h6>
                    <h2 class="fw-bold text-dark mb-0">@Model.FacultiesCount</h2>
                    <p class="text-muted small mt-2">Active academic divisions</p>
                </div>
                <i class="bi bi-mortarboard decorative-icon"></i>
            </div>
        </div>

        @* Departments *@
        <div class="col-xl-3 col-md-6">
            <div class="stat-card bg-white h-100 shadow-sm rounded-4 p-4 border-0 position-relative overflow-hidden">
                <div class="stat-icon bg-light-warning text-warning">
                    <i class="bi bi-diagram-3"></i>
                </div>
                <div class="stat-content mt-3">
                    <h6 class="text-uppercase text-muted fw-bold mb-1 small tracking-wider">Departments</h6>
                    <h2 class="fw-bold text-dark mb-0">@Model.DepartmentsCount</h2>
                    <p class="text-muted small mt-2">Specialized study programs</p>
                </div>
                <i class="bi bi-diagram-3 decorative-icon"></i>
            </div>
        </div>

        @* Courses *@
        <div class="col-xl-3 col-md-6">
            <div class="stat-card bg-white h-100 shadow-sm rounded-4 p-4 border-0 position-relative overflow-hidden">
                <div class="stat-icon bg-light-danger text-danger">
                    <i class="bi bi-book"></i>
                </div>
                <div class="stat-content mt-3">
                    <h6 class="text-uppercase text-muted fw-bold mb-1 small tracking-wider">Total Courses</h6>
                    <h2 class="fw-bold text-dark mb-0">@Model.CoursesCount</h2>
                    <p class="text-muted small mt-2">Educational subjects listed</p>
                </div>
                <i class="bi bi-book decorative-icon"></i>
            </div>
        </div>

    </div>

    @* Recent Activity Row *@
    <div class="row g-4">

        @* Latest Universities *@
        <div class="col-lg-7">
            <div class="card shadow-sm border-0 rounded-4 h-100 bg-white">
                <div class="card-header bg-white border-0 pt-4 px-4 d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold text-dark m-0">
                        <i class="bi bi-clock-history me-2 text-primary"></i> Recently Added Universities
                    </h5>
                    <a asp-controller="University" asp-action="Index" class="btn btn-sm btn-light-primary rounded-pill">View All</a>
                </div>
                <div class="card-body p-4">
                    <div class="table-responsive">
                        <table class="table table-hover table-striped align-middle mb-0">
                            <thead class="table-light small text-uppercase text-muted tracking-wider">
                                <tr>
                                    <th>University Name</th>
                                    <th>Type</th>
                                    <th>QS Rank</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var uni in Model.LatestUniversities)
                                {
                                    <tr>
                                        <td class="fw-semibold text-dark">@uni.Name</td>
                                        <td>
                                            @if (uni.Type == UniversityType.Governmental)
                                            {
                                                <span class="badge bg-light-primary text-primary rounded-pill px-3">Public</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-light-secondary text-secondary rounded-pill px-3">Private</span>
                                            }
                                        </td>
                                        <td><i class="bi bi-trophy text-warning me-1"></i> #@uni.Rank_QS</td>
                                        <td>
                                            <a asp-controller="University" asp-action="Details" asp-route-id="@uni.University_ID" class="btn btn-sm btn-outline-primary rounded-pill">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        @* Quick Actions - إضافة لمسة عملية للـ Dashboard *@
        <div class="col-lg-5">
            <div class="card shadow-sm border-0 rounded-4 h-100 bg-white">
                <div class="card-header bg-white border-0 pt-4 px-4">
                    <h5 class="fw-bold text-dark m-0"><i class="bi bi-lightning-charge me-2 text-warning"></i> Quick Actions</h5>
                </div>
                <div class="card-body p-4">
                    <div class="d-grid gap-3">
                        <a asp-controller="University" asp-action="Create" class="btn btn-main py-3 rounded-3 text-start d-flex align-items-center">
                            <i class="bi bi-plus-circle-fill fs-4 me-3"></i>
                            <div>
                                <div class="fw-bold">Add New University</div>
                                <div class="small opacity-75">Enter ranking, logo, and details.</div>
                            </div>
                        </a>
                        <a asp-controller="Department" asp-action="Create" class="btn btn-outline-success py-3 rounded-3 text-start d-flex align-items-center">
                            <i class="bi bi-building-plus fs-4 me-3"></i>
                            <div>
                                <div class="fw-bold">Add New Department</div>
                                <div class="small opacity-75">Define fees and admission rates.</div>
                            </div>
                        </a>
                        <a asp-controller="Course" asp-action="Create" class="btn btn-outline-danger py-3 rounded-3 text-start d-flex align-items-center">
                            <i class="bi bi-book-half fs-4 me-3"></i>
                            <div>
                                <div class="fw-bold">List New Course</div>
                                <div class="small opacity-75">Assign to specific departments.</div>
                            </div>
                        </a>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

@* Custom CSS for the new look *@
<style>
    /* ألوان خفيفة خلف الأيقونات */
    .bg-light-primary {
        background-color: rgba(13, 110, 253, 0.1);
    }

    .bg-light-success {
        background-color: rgba(25, 135, 84, 0.1);
    }

    .bg-light-warning {
        background-color: rgba(255, 193, 7, 0.1);
    }

    .bg-light-danger {
        background-color: rgba(220, 53, 69, 0.1);
    }

    .btn-light-primary {
        background-color: rgba(13, 110, 253, 0.05);
        color: #0d6efd;
        border: 1px solid rgba(13, 110, 253, 0.1);
    }

        .btn-light-primary:hover {
            background-color: rgba(13, 110, 253, 0.1);
        }

    /* تنسيق كروت الإحصائيات */
    .stat-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .stat-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
        }

    .stat-icon {
        width: 60px;
        height: 60px;
        border-radius: 15px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.8rem;
    }

    .tracking-wider {
        letter-spacing: 1px;
    }

    /* أيقونات ديكورية خلفية */
    .decorative-icon {
        position: absolute;
        bottom: -20px;
        right: -10px;
        font-size: 6rem;
        opacity: 0.03;
        transform: rotate(-15deg);
        pointer-events: none;
    }

    /* تحسينات الجدول */
    .table-hover tbody tr:hover {
        background-color: rgba(13, 110, 253, 0.02);
    }

    /* أزرار الإجراءات السريعة */
    .btn-main {
        background-color: #0d6efd;
        color: white;
        border: none;
    }

        .btn-main:hover {
            background-color: #0b5ed7;
            color: white;
        }
</style>