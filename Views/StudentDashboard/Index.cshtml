<link rel="stylesheet" href="~/css/Student.css" />

<div class="container mt-4">
    <div class="toast-container position-fixed top-0 end-0 p-3">
        <div id="liveToast" class="toast show align-items-center text-bg-success border-0">
            <div class="d-flex">
                <div class="toast-body">
                    @TempData["Success"]
                </div>
                <button type="button" class="btn-close me-2 m-auto" data-bs-dismiss="toast"></button>
            </div>
        </div>
    </div>
    }
    <!-- 🔹 Stats -->
    <div class="row">

        <!-- 👤 Student -->
        <div class="col-md-4 mb-3">
            <div class="card shadow stat-card text-center">
                <h6>👤 Student</h6>
                <h3>@(User.Identity?.Name ?? "Student")</h3>
            </div>
        </div>

        <!-- 🎯 GPA -->
        <div class="col-md-4 mb-3">
            <div class="card shadow stat-card text-center">
                <h6>🎯 GPA</h6>
                @{
                    int gpa = ViewBag.GPA != null ? (int)ViewBag.GPA : 0;
                }
                <h3>@gpa</h3>

                @if (gpa >= 85)
                {
                    <span class="badge bg-success">High</span>
                }
                else if (gpa >= 70)
                {
                    <span class="badge bg-warning text-dark">Medium</span>
                }
                else
                {
                    <span class="badge bg-danger">Low</span>
                }
            </div>
        </div>

        <!-- 📊 Majors -->
        <div class="col-md-4 mb-3">
            <div class="card shadow stat-card text-center">
                <h6>📊 Majors</h6>
                <h3>@(ViewBag.MajorsCount ?? 0)</h3>
            </div>
        </div>

    </div>

    <!-- 🔥 Top Majors -->
    <h4 class="mt-4 mb-3">🔥 Top Majors</h4>

    <div class="row">

        @if (ViewBag.TopMajors != null && ViewBag.TopMajors.Count > 0)
        {
            foreach (var major in ViewBag.Majors)
            {
                <div class="col-md-4 mb-3">
                    <div class="card shadow major-card">
                        <div class="card-body">
                            <h5>@major</h5>
                            <p class="text-muted">Recommended based on your GPA</p>
                        </div>
                    </div>
                </div>
            }
        }


            @if (ViewBag.Majors != null && ViewBag.Majors.Count > 0)
            {
                foreach (var major in ViewBag.Majors)
                {
                    <div class="col-md-4 mb-3">
                        <div class="card major-card p-3">
                            <h5>@major</h5>
                            <p class="text-muted">Recommended based on your GPA</p>
                            <button class="btn btn-sm btn-primary">View</button>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="text-center mt-4">
                    <h5>😢 No Majors Found</h5>
                    <p class="text-muted">Complete onboarding to see recommendations</p>
                </div>
            }
        <script>
            setTimeout(() => {
                let toast = document.getElementById('liveToast');
                if (toast) toast.style.display = 'none';
            }, 4000);
        </script>
