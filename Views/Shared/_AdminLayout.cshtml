<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - Admin Panel</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/style.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="icon" type="image/png" href="~/images/joUniGuideLogo-removebg-preview.png">
</head>
<body class="admin-body">

    <div class="sidebar">
        <div class="sidebar-logo text-center py-4">
            <a asp-controller="Admin" asp-action="Dashboard" class="text-decoration-none">
                <img src="~/images/joUniGuideLogo-removebg-preview.png"
                     alt="Logo"
                     style="margin-top: -34px; height: 100px; width: auto; filter: drop-shadow(0px 4px 6px rgba(0,0,0,0.3));">
                <div class="mt-2 fw-bold text-white small text-uppercase" style="letter-spacing: 1px;">
                    JO-UNI-Guide
                </div>
            </a>
        </div>

        <nav class="sidebar-nav">
            <a asp-controller="Admin" asp-action="Dashboard" class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "Dashboard" ? "active" : "")">
                <i class="bi bi-speedometer2"></i> Dashboard
            </a>
            <a asp-controller="University" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "University" ? "active" : "")">
                <i class="bi bi-buildings"></i> Universities
            </a>
            <a asp-controller="Faculty" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Faculty" ? "active" : "")">
                <i class="bi bi-mortarboard"></i> Faculties
            </a>
            <a asp-controller="Department" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Department" ? "active" : "")">
                <i class="bi bi-diagram-3"></i> Departments
            </a>
            <a asp-controller="Course" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Course" ? "active" : "")">
                <i class="bi bi-book"></i> Courses
            </a>

            @if (User.IsInRole("SuperAdmin"))
            {
                <a asp-controller="Users" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Users" ? "active" : "")">
                    <i class="bi bi-people"></i> Admins
                </a>
            }
        </nav>

        <div class="sidebar-footer" style="margin-bottom: 20px;">
            <form asp-controller="Account" asp-action="Logout" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="logout-btn w-100 text-start border-0 bg-transparent text-white opacity-75 hover-opacity-100">
                    <i class="bi bi-box-arrow-right me-2"></i> Logout
                </button>
            </form>
        </div>
    </div>

    <div class="main-content d-flex flex-column min-vh-100">
        <div class="px-4">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show mt-3 shadow-sm border-0">
                    @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
        </div>
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show mt-3" role="alert" style="width: 97%; margin-left: 18px;">
                @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <div class="content p-4 flex-grow-1">
            @RenderBody()
        </div>

        <footer class="admin-footer py-3 border-top bg-white mt-auto">
            <div class="container-fluid text-center text-muted small">
                &copy; @DateTime.Now.Year JO UNI Guide - Admin Panel
            </div>
        </footer>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>