<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - JO-UNI Guide</title>

    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700&family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
    <link rel="stylesheet" href="~/css/student-style.css" asp-append-version="true" />
</head>
<body>
    <div class="d-flex">

        <div class="student-sidebar shadow-lg">
            <div class="sidebar-header">
                <img src="~/images/joUniGuideLogo-removebg-preview.png" alt="Logo" class="img-fluid mb-3" style="height: 65px;">
                <h5 class="text-white fw-bold mb-0">JO-UNI Guide</h5>
                <span class="text-white-50 small">Your Academic Gateway</span>
            </div>

            <ul class="nav flex-column">
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Dashboard" ? "active" : "")"
                       asp-controller="Student" asp-action="Dashboard">
                        <i class="bi bi-grid-1x2-fill"></i> Dashboard
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "ProposedMajors" ? "active" : "")"
                       asp-controller="Student" asp-action="ProposedMajors">
                        <i class="bi bi-mortarboard-fill"></i> Proposed Majors
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "SmartSearch" ? "active" : "")"
                       asp-controller="Student" asp-action="SmartSearch">
                        <i class="bi bi-search-heart-fill"></i> Smart Search
                    </a>
                </li>

                <li class="nav-item mt-auto pt-3 border-top" style="border-color: rgba(255,255,255,0.1) !important;">
                    <form asp-controller="Account" asp-action="Logout" method="post" class="w-100">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="nav-link text-danger w-100 border-0 bg-transparent text-start">
                            <i class="bi bi-box-arrow-left"></i> Logout
                        </button>
                    </form>
                </li>
            </ul>
        </div>

        <div class="main-content">
            <nav class="navbar navbar-expand main-navbar">
                <div class="container-fluid px-0">
                    <h5 class="navbar-brand fw-bold mb-0">@ViewData["Title"]</h5>

                    <div class="ms-auto d-flex align-items-center gap-3">
                        <div class="user-profile-circle d-flex justify-content-center align-items-center">
                            @(User.Identity?.Name?.FirstOrDefault().ToString().ToUpper() ?? "S")
                        </div>
                    </div>
                </div>
            </nav>

            <div class="p-4 p-md-5">
                @RenderBody()
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>