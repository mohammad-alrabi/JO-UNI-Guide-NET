<!DOCTYPE html>
<html lang="en">
 @* جعلناها en لأن المصطلحات برمجية، وإذا أردتِ دعم العربي بالكامل حوليها لـ ar و dir="rtl" *@
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - JO-UNI Guide</title>

    @* نستخدم النسخة العادية من Bootstrap لأننا سنعتمد تصميم الـ Sidebar الغربي (يسار) *@
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="~/css/student-style.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body class="bg-light">
    <div class="d-flex">
        <div class="student-sidebar p-3 vh-100 sticky-top shadow">
            <div class="sidebar-header text-center mb-4">
                <img src="~/images/joUniGuideLogo-removebg-preview.png" alt="Logo" class="img-fluid mb-2" style="height: 60px;">
                <h5 class="text-white fw-bold">JO-UNI Guide</h5>
            </div>

            <ul class="nav flex-column gap-2">
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Dashboard" ? "active" : "")"
                       asp-controller="Student" asp-action="Dashboard">
                        <i class="bi bi-speedometer2 me-2"></i> Dashboard
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Universities" ? "active" : "")"
                       asp-controller="Home" asp-action="Universities">
                        <i class="bi bi-buildings me-2"></i> All Universities
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "SmartSearch" ? "active" : "")"
                       asp-controller="Student" asp-action="SmartSearch">
                        <i class="bi bi-search-heart me-2"></i> Smart Search
                    </a>
                </li>
                <li class="nav-item mt-4 pt-4 border-top border-secondary">
                    <a class="nav-link text-danger" asp-controller="Account" asp-action="Logout">
                        <i class="bi bi-box-arrow-left me-2"></i> Logout
                    </a>
                </li>
            </ul>
        </div>

        <div class="flex-grow-1 main-content">
            <nav class="navbar navbar-expand navbar-white bg-white shadow-sm px-4 py-3">
                <div class="container-fluid">
                    <span class="navbar-brand fw-bold text-dark">@ViewData["Title"]</span>

                    <div class="ms-auto d-flex align-items-center gap-3">
                        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary btn-sm rounded-pill">
                            <i class="bi bi-house-door me-1"></i> Public Site
                        </a>
                        <div class="user-profile-circle bg-primary text-white">
                            @User.Identity.Name?.Substring(0, 1).ToUpper()
                        </div>
                    </div>
                </div>
            </nav>

            <div class="container-fluid p-4">
                @RenderBody()
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>