@model JO_UNI_Guide.Models.University
@using JO_UNI_Guide.Models
@{
    ViewData["Title"] = Model.Name;
    Layout = "_StudentLayout";
}

@if (Model.Latitude.HasValue && Model.Longitude.HasValue)
{
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
}

<div class="uni-hero-modern">
    <div class="uni-hero-box">
        <div class="uni-logo-floating">
            <img src="@Model.Logo" />
        </div>
        <h2 class="uni-title-modern">@Model.Name</h2>
        <div class="uni-top-row">
            <span class="uni-type-modern">
                @(Model.Type == UniversityType.Governmental ? "Public" : "Private")
            </span>
            @if (!string.IsNullOrEmpty(Model.Rank_QS))
            {
                <span class="uni-rank-modern">QS #@Model.Rank_QS</span>
            }
        </div>
        <div class="uni-info-grid">
            <div class="uni-info-item"><i class="bi bi-geo-alt"></i> @Model.Location</div>
            <div class="uni-info-item"><i class="bi bi-envelope"></i> @Model.Email</div>
            <div class="uni-info-item"><i class="bi bi-phone"></i> @Model.ContactPhone</div>
            <a href="@Model.WebsiteUrl" class="uni-info-item">
                <i class="bi bi-globe"></i> Website
            </a>
        </div>
        <div class="uni-desc-modern">@Model.Description</div>
    </div>
</div>

@* ✅ الخريطة هون *@
@if (Model.Latitude.HasValue && Model.Longitude.HasValue)
{
    <h4 class="section-heading mb-3 mt-4">
        <span class="heading-line"></span>
        <i class="bi bi-geo-alt-fill text-danger me-2"></i> University Location
    </h4>
    <div class="card border-0 shadow-sm mb-5 overflow-hidden" style="border-radius: var(--radius-lg);">
        <div id="map" style="height: 320px; width: 100%;"></div>
    </div>
}

<h4 class="section-heading mb-4">
    <span class="heading-line"></span>
    <i class="bi bi-mortarboard-fill text-danger me-2"></i> Faculties & Available Programs
</h4>

@if (!Model.Faculties.Any())
{
    <div class="empty-faculties card p-5 text-center border-0 shadow-sm">
        <i class="bi bi-folder-x display-1 text-muted opacity-25"></i>
        <h5 class="mt-3 fw-bold text-muted">No departments listed yet.</h5>
    </div>
}
else
{
    <div class="accordion custom-accordion shadow-sm border-0" id="facultiesAccordion">
        @{
            int index = 0;
        }
        @foreach (var faculty in Model.Faculties)
        {
            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button @(index == 0 ? "" : "collapsed")" type="button"
                            data-bs-toggle="collapse" data-bs-target="#faculty-@faculty.Faculty_ID">
                        <div class="d-flex align-items-center w-100 pe-3">
                            <div class="faculty-icon-box me-3">
                                <i class="bi bi-book"></i>
                            </div>
                            <span class="fw-bold">@faculty.Name</span>
                            <span class="badge bg-light text-muted border ms-auto">@faculty.Departments.Count Majors</span>
                        </div>
                    </button>
                </h2>
                <div id="faculty-@faculty.Faculty_ID"
                     class="accordion-collapse collapse @(index == 0 ? "show" : "")"
                     data-bs-parent="#facultiesAccordion">
                    <div class="accordion-body p-0 bg-white">
                        <div class="table-responsive">
                            <table class="table premium-table mb-0">
                                <thead>
                                    <tr>
                                        <th class="ps-4">Academic Program</th>
                                        <th class="text-center">Min. Rate</th>
                                        <th class="text-center">Price / Hr</th>
                                        <th class="text-center">Credit Hours</th>
                                        <th class="text-end pe-4">Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var dept in faculty.Departments)
                                    {
                                        <tr>
                                            <td class="ps-4 fw-bold text-dark">@dept.DepartmentName</td>
                                            <td class="text-center">
                                                <span class="rate-badge-alt">@dept.AcceptanceRate%</span>
                                            </td>
                                            <td class="text-center fw-bold text-success">
                                                @dept.HourPrice <small>JOD</small>
                                            </td>
                                            <td class="text-center text-muted">@dept.TotalCreditHours hrs</td>
                                            <td class="text-end pe-4">
                                                <a asp-action="MajorDetails" asp-controller="Student"
                                                   asp-route-id="@dept.Department_ID"
                                                   class="btn btn-view-major">
                                                    Details <i class="bi bi-chevron-right ms-1"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
            index++;
        }
    </div>
}

@section Scripts {
    @if (Model.Latitude.HasValue && Model.Longitude.HasValue)
    {
        <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
        <text>
            <script>
                var map = L.map('map').setView([@Model.Latitude, @Model.Longitude], 15);
                L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                    attribution: '© OpenStreetMap contributors'
                }).addTo(map);
                L.marker([@Model.Latitude, @Model.Longitude])
                    .addTo(map)
                    .bindPopup('<strong>@Model.Name</strong><br>@Model.Location')
                    .openPopup();
            </script>
        </text>
    }
}