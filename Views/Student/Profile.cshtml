@model JO_UNI_Guide.Models.ProfileViewModel
@{
    ViewData["Title"] = "My Profile";
    Layout = "_StudentLayout";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success rounded-3 mb-4 d-flex align-items-center gap-2" id="successAlert">
        <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
    </div>
}

<div class="row g-4">

    <!-- LEFT CARD -->
    <div class="col-lg-4">
        <div class="profile-header text-center p-4">

            <div class="profile-avatar mx-auto mb-3"
                 style="width:80px;height:80px;border-radius:50%;background:var(--brand-red);
                        display:flex;align-items:center;justify-content:center;
                        font-size:2rem;font-weight:700;color:white;">
                @(Model.Name?.FirstOrDefault().ToString().ToUpper() ?? "S")
            </div>

            <div class="profile-name fw-bold fs-5">@(Model.Name ?? "Student")</div>
            <div class="profile-email text-muted small mb-3">@Model.Email</div>

            <div class="d-flex flex-wrap justify-content-center gap-2">
                <span class="badge bg-light text-dark border px-3 py-2">
                    <i class="bi bi-heart-fill text-danger me-1"></i> @Model.FavoritesCount Favorites
                </span>
                <span class="badge bg-light text-dark border px-3 py-2">
                    <i class="bi bi-bar-chart-fill text-primary me-1"></i>
                    @(Model.EquivalentGrade?.ToString("0.0") ?? "0.0")%
                </span>
                <span class="badge bg-danger text-white px-3 py-2">
                    <i class="bi bi-award-fill me-1"></i> @Model.CertificateType
                </span>
            </div>
        </div>

        <!-- Quick Info -->
        <div class="section-card mt-3 p-3">
            <div class="section-card-title fw-bold mb-3">
                <i class="bi bi-info-circle-fill text-danger me-1"></i> Quick Info
            </div>

            <div class="d-flex flex-column gap-3">
                <div class="p-2 bg-light rounded-3">
                    <div class="small text-muted fw-bold">Preferred University</div>
                    <div class="fw-bold">
                        <i class="bi bi-building me-1 text-danger"></i>
                        @(Model.PreferredUniType ?? "Not set")
                    </div>
                </div>

                <div class="p-2 bg-light rounded-3">
                    <div class="small text-muted fw-bold">Original Grade</div>
                    <div class="fw-bold">
                        <i class="bi bi-pencil-fill me-1 text-danger"></i>
                        @(Model.OriginalGrade ?? 0)
                    </div>
                </div>

                <div class="p-2 bg-light rounded-3">
                    <div class="small text-muted fw-bold">Equivalent Grade</div>
                    <div class="fw-bold text-primary">
                        <i class="bi bi-bar-chart me-1"></i>
                        @(Model.EquivalentGrade?.ToString("0.0") ?? "0.0")%
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- RIGHT FORM -->
    <div class="col-lg-8">
        <form method="post" id="profileForm">

            <!-- Personal Information -->
            <div class="section-card p-4 mb-3">
                <div class="section-card-title d-flex justify-content-between align-items-center mb-3">
                    <span class="fw-bold">
                        <i class="bi bi-person-fill text-danger me-2"></i>Personal Information
                    </span>
                    <div class="d-flex gap-2">
                        <button type="button" id="btnEdit" class="btn btn-sm btn-outline-danger rounded-pill px-3">
                            <i class="bi bi-pencil-fill me-1"></i> Edit
                        </button>
                        <button type="button" id="btnCancel" class="btn btn-sm btn-outline-secondary rounded-pill px-3 d-none">
                            <i class="bi bi-x-lg me-1"></i> Cancel
                        </button>
                        <button type="submit" id="btnSave" class="btn btn-sm btn-danger rounded-pill px-3 d-none">
                            <i class="bi bi-check-lg me-1"></i> Save
                        </button>
                    </div>
                </div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="small fw-bold text-muted">Full Name</label>
                        <input type="text" name="Name"
                               value="@Model.Name"
                               class="form-control profile-field"
                               disabled />
                    </div>

                    <div class="col-md-6">
                        <label class="small fw-bold text-muted">Email</label>
                        <input type="email"
                               value="@Model.Email"
                               class="form-control"
                               disabled />
                    </div>

                    <div class="col-md-6">
                        <label class="small fw-bold text-muted">Preferred University Type</label>
                        <select name="PreferredUniType" class="form-select profile-field" disabled>
                            <option value="">-- Select --</option>
                            <option value="All" selected="@(Model.PreferredUniType == "All")">All</option>
                            <option value="Governmental" selected="@(Model.PreferredUniType == "Governmental")">Public</option>
                            <option value="Private" selected="@(Model.PreferredUniType == "Private")">Private</option>
                        </select>
                    </div>
                </div>
            </div>

            <!-- Academic Information -->
            <div class="section-card p-4">
                <div class="section-card-title fw-bold mb-3">
                    <i class="bi bi-mortarboard-fill text-danger me-2"></i>Academic Information
                </div>

                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="small fw-bold text-muted">Certificate Type</label>
                        <input type="text"
                               value="@Model.CertificateType"
                               class="form-control"
                               disabled />
                        <input type="hidden" name="CertificateType" value="@Model.CertificateType" />
                    </div>

                    <div class="col-md-4">
                        <label class="small fw-bold text-muted">Original Grade</label>
                        <input type="number"
                               name="OriginalGrade"
                               value="@(Model.OriginalGrade ?? 0)"
                               class="form-control profile-field"
                               step="0.01"
                               disabled />
                    </div>

                    <div class="col-md-4">
                        <label class="small fw-bold text-muted">Equivalent Grade (%)</label>
                        <input type="text"
                               value="@(Model.EquivalentGrade?.ToString("0.0") ?? "0.0")"
                               class="form-control"
                               disabled />
                    </div>
                </div>
            </div>

        </form>
    </div>
</div>

@section Scripts {
    <script>
        // رسالة النجاح تختفي بعد ثانيتين
        const alert = document.getElementById('successAlert');
        if (alert) {
            setTimeout(() => {
                alert.style.transition = 'opacity 0.5s';
                alert.style.opacity = '0';
                setTimeout(() => alert.remove(), 500);
            }, 2000);
        }

        const btnEdit = document.getElementById('btnEdit');
        const btnCancel = document.getElementById('btnCancel');
        const btnSave = document.getElementById('btnSave');
        const fields = document.querySelectorAll('.profile-field');

        const originalValues = {};
        fields.forEach(f => originalValues[f.name] = f.value);

        btnEdit.addEventListener('click', () => {
            fields.forEach(f => f.disabled = false);
            btnEdit.classList.add('d-none');
            btnCancel.classList.remove('d-none');
            btnSave.classList.remove('d-none');
        });

        btnCancel.addEventListener('click', () => {
            fields.forEach(f => {
                f.value = originalValues[f.name];
                f.disabled = true;
            });
            btnEdit.classList.remove('d-none');
            btnCancel.classList.add('d-none');
            btnSave.classList.add('d-none');
        });
    </script>
}