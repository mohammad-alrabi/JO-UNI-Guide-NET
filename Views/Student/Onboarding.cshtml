@model JO_UNI_Guide.Models.OnboardingViewModel
@{
    ViewData["Title"] = "Student Setup";
    Layout = "_StudentLayout";
}

<div class="container mt-5 mb-5 animate__animated animate__fadeInUp">
    <div class="card shadow-lg p-4 mx-auto border-0" style="max-width:520px; border-radius: 24px;">

        <!-- Header -->
        <div class="text-center mb-4">
            <div class="d-inline-flex align-items-center justify-content-center bg-light rounded-circle mb-3"
                 style="width: 70px; height: 70px;">
                <i class="bi bi-rocket-takeoff-fill fs-2 text-danger"></i>
            </div>
            <h3 class="fw-bold">Welcome Aboard! 🎓</h3>
            <p class="text-muted small">Tell us about your background to get personalized major recommendations.</p>
        </div>

        <!-- Progress Steps -->
        <div class="d-flex justify-content-center gap-2 mb-4">
            <span class="badge rounded-pill bg-danger px-3 py-2">1. Certificate</span>
            <span class="badge rounded-pill bg-secondary px-3 py-2">2. Grade</span>
            <span class="badge rounded-pill bg-secondary px-3 py-2">3. Preference</span>
        </div>

        <form asp-action="Onboarding" method="post" id="onboardingForm">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly"
                 class="alert alert-danger border-0 rounded-3 small mb-3"></div>

            <!-- CERTIFICATE TYPE -->
            <div class="mb-3">
                <label asp-for="CertificateType" class="form-label fw-bold small text-uppercase text-muted">
                    <i class="bi bi-award me-1"></i> Certificate Type
                </label>
                <select asp-for="CertificateType"
                        class="form-select shadow-sm"
                        id="certTypeSelect"
                        asp-items="Html.GetEnumSelectList<JO_UNI_Guide.Models.CertificateType>()">
                    <option value="">-- Select your certificate --</option>
                </select>
                <span asp-validation-for="CertificateType" class="text-danger small mt-1 d-block"></span>
            </div>

            <!-- GRADE HINT -->
            <div id="gradeHint" class="alert alert-info border-0 rounded-3 small py-2 px-3 mb-2 d-none">
                <i class="bi bi-info-circle me-1"></i>
                <span id="gradeHintText"></span>
            </div>

            <!-- ORIGINAL GRADE -->
            <div class="mb-3">
                <label asp-for="OriginalGrade" class="form-label fw-bold small text-uppercase text-muted">
                    <i class="bi bi-bar-chart me-1"></i> Your Grade
                </label>
                <div class="input-group shadow-sm rounded-3 overflow-hidden">
                    <span class="input-group-text bg-white border-end-0 text-muted">
                        <i class="bi bi-pencil-fill"></i>
                    </span>
                    <input asp-for="OriginalGrade"
                           class="form-control border-start-0 ps-0"
                           id="gradeInput"
                           placeholder="e.g., 85.5"
                           step="0.01" />
                </div>
                <span asp-validation-for="OriginalGrade" class="text-danger small mt-1 d-block"></span>
            </div>

            <!-- UNIVERSITY TYPE -->
            <div class="mb-4">
                <label asp-for="PreferredUniType" class="form-label fw-bold small text-uppercase text-muted">
                    <i class="bi bi-building me-1"></i> Preferred University Type
                </label>
                <div class="row g-2">
                    <div class="col-4">
                        <input type="radio" class="btn-check" name="PreferredUniType" id="uniAll" value="All" />
                        <label class="btn btn-outline-secondary w-100 rounded-3" for="uniAll">
                            <i class="bi bi-globe2 d-block mb-1"></i> All
                        </label>
                    </div>
                    <div class="col-4">
                        <input type="radio" class="btn-check" name="PreferredUniType" id="uniPublic" value="Governmental" />
                        <label class="btn btn-outline-primary w-100 rounded-3" for="uniPublic">
                            <i class="bi bi-bank d-block mb-1"></i> Public
                        </label>
                    </div>
                    <div class="col-4">
                        <input type="radio" class="btn-check" name="PreferredUniType" id="uniPrivate" value="Private" />
                        <label class="btn btn-outline-danger w-100 rounded-3" for="uniPrivate">
                            <i class="bi bi-building-check d-block mb-1"></i> Private
                        </label>
                    </div>
                </div>
                <span asp-validation-for="PreferredUniType" class="text-danger small mt-1 d-block"></span>
            </div>

            <div class="d-grid mt-2">
                <button type="submit" id="btnSubmit"
                        class="btn btn-danger rounded-pill fw-bold shadow-sm py-2">
                    <i class="bi bi-check-circle me-2"></i> Save & Continue
                </button>
            </div>

        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function () {
            const $form = $('#onboardingForm');
            const $btn = $('#btnSubmit');

            $form.on('submit', function () {
                if ($form.valid()) {
                    $btn.prop('disabled', true);
                    $btn.html('<span class="spinner-border spinner-border-sm me-2"></span> Saving...');
                }
            });
        });

        // Grade hint حسب نوع الشهادة
        const hints = {
            "Tawjihi":             "Enter your grade from 0 to 100",
            "Saudi":               "Enter your grade from 0 to 100",
            "AmericanHighSchool":  "Enter your GPA from 0.0 to 4.0",
            "IGCSE":               "Enter your score from 0 to 8",
            "IB":                  "Enter your score from 1 to 45",
            "AmericanDiploma":     "Enter your grade from 0 to 100",
            "Other":               "Enter your grade from 0 to 100"
        };

        document.getElementById('certTypeSelect').addEventListener('change', function () {
            const hint = hints[this.value];
            const hintBox = document.getElementById('gradeHint');
            const hintText = document.getElementById('gradeHintText');

            if (hint) {
                hintText.textContent = hint;
                hintBox.classList.remove('d-none');
            } else {
                hintBox.classList.add('d-none');
            }
        });
    </script>
}