@model JO_UNI_Guide.Models.OnboardingViewModel
@{
    ViewData["Title"] = "Student Setup";
    Layout = "_studentLayout";
}

<div class="container mt-5">
    <div class="card shadow-lg p-4 mx-auto border-0" style="max-width:550px; border-radius: 15px;">
        <div class="text-center mb-4">
            <h3 class="fw-bold">🎓 Student Setup</h3>
            <p class="text-muted small">أكمل بياناتك لنقترح لك أفضل التخصصات</p>
        </div>

        <form asp-action="Onboarding" method="post" id="onboardingForm">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

         
            <div class="mb-4">
                <label asp-for="GPA" class="form-label fw-bold">معدل التوجيهي</label>
                <div class="input-group">
                    <span class="input-group-text bg-white"><i class="bi bi-percent"></i></span>
                    <input asp-for="GPA" class="form-control" placeholder="مثلاً: 85.5" step="0.1" />
                </div>
                <span asp-validation-for="GPA" class="text-danger small"></span>
            </div>

           
            <div class="mb-4">
                <label asp-for="TawjihiTrack" class="form-label fw-bold">الفرع الدراسي</label>
                <select asp-for="TawjihiTrack" class="form-select"
                        asp-items="Html.GetEnumSelectList<JO_UNI_Guide.Models.TawjihiTrack>()">
                    <option value="">-- اختر الفرع --</option>
                </select>
                <span asp-validation-for="TawjihiTrack" class="text-danger small"></span>
            </div>

           
            <div class="mb-4">
                <label asp-for="PreferredUniType" class="form-label fw-bold">نوع الجامعة المفضّل</label>
                <select asp-for="PreferredUniType" class="form-select">
                    <option value="">-- اختر --</option>
                    <option value="All">الكل (حكومي وخاص)</option>
                    <option value="Public">حكومي فقط</option>
                    <option value="Private">خاص فقط</option>
                </select>
                <span asp-validation-for="PreferredUniType" class="text-danger small"></span>
            </div>

            <div class="d-grid shadow-sm">
                <button type="submit" id="btnSubmit" class="btn btn-primary py-2 fw-bold">
                    حفظ البيانات والدخول <i class="bi bi-arrow-right-short"></i>
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function () {
            const $form = $('#onboardingForm');
            const $btn = $('#btnSubmit');

            $form.on('submit', function () {
                if ($form.valid()) {
                    $btn.prop('disabled', true);
                    $btn.html('<span class="spinner-border spinner-border-sm"></span> جاري التحميل...');
                } else {
                    return false;
                }
            });
        });
    </script>
}