@model JO_UNI_Guide.Models.UniversitiesListViewModel
@using JO_UNI_Guide.Models
@{
    ViewData["Title"] = "Universities";
    Layout = "_StudentLayout";
}
<div class="mb-4">
    <ul class="nav nav-pills" id="pills-tab" role="tablist">
        <li class="nav-item">
            <button class="nav-link active me-2" data-bs-toggle="pill" data-bs-target="#public">
                <i class="bi bi-bank me-2"></i>Public Universities
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link" data-bs-toggle="pill" data-bs-target="#private">
                <i class="bi bi-building-check me-2"></i>Private Universities
            </button>
        </li>
    </ul>
</div>

<div class="tab-content">
    <div class="tab-pane fade show active" id="public">
        @if (!Model.PublicUniversities.Any())
        {
            <div class="empty-state">
                <i class="bi bi-buildings"></i>
                <h5 style="color:var(--text-main);font-weight:700;">No public universities found</h5>
            </div>
        }
        else
        {
            <p class="results-count">
                <span>@Model.PublicUniversities.Count</span> public universit@(Model.PublicUniversities.Count != 1 ? "ies" : "y") available
            </p>
            <div class="row g-4">
                @foreach (var uni in Model.PublicUniversities)
                {
                    <div class="col-md-4">
                        <div class="card uni-card h-100">
                            <div class="uni-logo-wrapper">
                                @if (!string.IsNullOrEmpty(uni.Logo))
                                {
                                    <img src="@uni.Logo" alt="@uni.Name" class="uni-logo-img">
                                }
                                else
                                {
                                    <div class="uni-logo-placeholder">
                                        <i class="bi bi-building"></i>
                                    </div>
                                }
                            </div>
                            <div class="card-body d-flex flex-column p-4">
                                <span class="badge align-self-start mb-2 px-3 rounded-pill"
                                      style="background:rgba(13,202,240,0.1);color:#0dcaf0;font-size:10px;font-weight:700;">
                                    Public
                                </span>
                                <h5 class="fw-bold mb-1" style="color:var(--text-main);">@uni.Name</h5>
                                <p class="small mb-3" style="color:var(--text-muted);">
                                    <i class="bi bi-geo-alt-fill text-danger me-1"></i>@uni.Location
                                </p>
                                @if (!string.IsNullOrEmpty(uni.Description))
                                {
                                    <p class="text-muted small mb-3" style="line-height:1.6;">
                                        @(uni.Description.Length > 90 ? uni.Description.Substring(0, 87) + "..." : uni.Description)
                                    </p>
                                }
                                <div class="mt-auto border-top pt-3">
                                    <a asp-action="UniversityDetails" asp-controller="Student"
                                       asp-route-id="@uni.University_ID"
                                       class="btn btn-uni w-100">
                                        Explore Majors <i class="bi bi-arrow-right-short ms-1"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    <div class="tab-pane fade" id="private">
        @if (!Model.PrivateUniversities.Any())
        {
            <div class="empty-state">
                <i class="bi bi-buildings"></i>
                <h5 style="color:var(--text-main);font-weight:700;">No private universities found</h5>
            </div>
        }
        else
        {
            <p class="results-count">
                <span>@Model.PrivateUniversities.Count</span> private universit@(Model.PrivateUniversities.Count != 1 ? "ies" : "y") available
            </p>
            <div class="row g-4">
                @foreach (var uni in Model.PrivateUniversities)
                {
                    <div class="col-md-4">
                        <div class="card uni-card h-100">
                            <div class="uni-logo-wrapper">
                                @if (!string.IsNullOrEmpty(uni.Logo))
                                {
                                    <img src="@uni.Logo" alt="@uni.Name" class="uni-logo-img">
                                }
                                else
                                {
                                    <div class="uni-logo-placeholder">
                                        <i class="bi bi-building"></i>
                                    </div>
                                }
                            </div>
                            <div class="card-body d-flex flex-column p-4">
                                <span class="badge align-self-start mb-2 px-3 rounded-pill"
                                      style="background:rgba(212,175,55,0.1);color:#7a5c00;font-size:10px;font-weight:700;">
                                    Private
                                </span>
                                <h5 class="fw-bold mb-1" style="color:var(--text-main);">@uni.Name</h5>
                                <p class="small mb-3" style="color:var(--text-muted);">
                                    <i class="bi bi-geo-alt-fill text-danger me-1"></i>@uni.Location
                                </p>
                                @if (!string.IsNullOrEmpty(uni.Description))
                                {
                                    <p class="text-muted small mb-3" style="line-height:1.6;">
                                        @(uni.Description.Length > 90 ? uni.Description.Substring(0, 87) + "..." : uni.Description)
                                    </p>
                                }
                                <div class="mt-auto border-top pt-3">
                                    <a asp-action="UniversityDetails" asp-controller="Student"
                                       asp-route-id="@uni.University_ID"
                                       class="btn btn-uni w-100">
                                        Explore Majors <i class="bi bi-arrow-right-short ms-1"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>