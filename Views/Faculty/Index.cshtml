@model JO_UNI_Guide.Helpers.PaginatedList<JO_UNI_Guide.Models.Faculty>

@{
    ViewData["Title"] = "Faculties";
    Layout = "_AdminLayout";
}

<div class="container py-4">

    @* Header Section *@
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div>
            <h2 class="page-title mb-0">Faculties</h2>
            <p class="text-muted small">Manage all faculties and their universities</p>
        </div>
        <a asp-action="Create" class="btn btn-primary px-4 rounded-pill shadow-sm">
            <i class="bi bi-plus-lg me-2"></i> Add Faculty
        </a>
    </div>

    @* Search Section *@
    <div class="card shadow-sm border-0 mb-4 rounded-4 p-3 bg-white">
        <form asp-action="Index" method="get">
            <div class="row g-2">
                <div class="col-md-9">
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0"><i class="bi bi-search"></i></span>
                        <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" class="form-control border-start-0 bg-light" placeholder="Search by faculty or university name..." />
                    </div>
                </div>
                <div class="col-md-3 d-flex gap-2">
                    <button type="submit" class="btn btn-dark w-100 shadow-sm">Search</button>
                    <a asp-action="Index" class="btn btn-outline-secondary w-100 shadow-sm">Reset</a>
                </div>
            </div>
        </form>
    </div>

    @* Table Section *@
    <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0 text-center">
                <thead class="table-light text-uppercase small fw-bold">
                    <tr>
                        <th class="py-3 text-start ps-4">Faculty Name</th>
                        <th class="py-3">University</th>
                        <th class="py-3">Actions</th>
                    </tr>
                </thead>
                <tbody class="border-top-0">
                    @if (Model.Count == 0)
                    {
                        <tr>
                            <td colspan="3" class="text-center py-5 text-muted">
                                <i class="bi bi-folder-x fs-1 d-block mb-2"></i>
                                No faculties found.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-bold text-dark py-3 text-start ps-4">
                                    <i class="bi bi-mortarboard me-2 text-primary"></i> @item.Name
                                </td>
                                <td class="text-muted">
                                    <span class="badge bg-light text-dark border small fw-normal px-3 py-2 rounded-pill">
                                        <i class="bi bi-building me-1 text-secondary"></i> @item.University?.Name
                                    </span>
                                </td>
                                <td>
                                    @* Manage Dropdown - ??? ????? ??? Department *@
                                    <div class="dropdown">
                                        <button class="btn btn-sm btn-light border dropdown-toggle rounded-pill px-3 shadow-sm" type="button" data-bs-toggle="dropdown">
                                            Manage
                                        </button>
                                        <ul class="dropdown-menu dropdown-menu-end shadow border-0 rounded-3">
                                            <li>
                                                <a class="dropdown-item py-2" asp-action="Details" asp-route-id="@item.Faculty_ID">
                                                    <i class="bi bi-eye text-info me-2"></i> Details
                                                </a>
                                            </li>
                                            <li>
                                                <a class="dropdown-item py-2" asp-action="Edit" asp-route-id="@item.Faculty_ID">
                                                    <i class="bi bi-pencil text-warning me-2"></i> Edit
                                                </a>
                                            </li>
                                            <li><hr class="dropdown-divider opacity-50"></li>
                                            <li>
                                                <a class="dropdown-item py-2 text-danger" asp-action="Delete" asp-route-id="@item.Faculty_ID">
                                                    <i class="bi bi-trash me-2"></i> Delete
                                                </a>
                                            </li>
                                        </ul>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    @* Pagination Section *@
    @if (Model.TotalPages > 1)
    {
        <div class="d-flex justify-content-center align-items-center gap-3 mt-4">
            <a asp-action="Index"
               asp-route-pageNumber="@(Model.PageIndex - 1)"
               asp-route-currentFilter="@ViewData["CurrentFilter"]"
               class="btn btn-white shadow-sm border @(Model.HasPreviousPage ? "" : "disabled text-muted")">
                <i class="bi bi-chevron-left"></i> Previous
            </a>

            <span class="fw-bold text-muted small">
                Page @Model.PageIndex of @Model.TotalPages
            </span>

            <a asp-action="Index"
               asp-route-pageNumber="@(Model.PageIndex + 1)"
               asp-route-currentFilter="@ViewData["CurrentFilter"]"
               class="btn btn-white shadow-sm border @(Model.HasNextPage ? "" : "disabled text-muted")">
                Next <i class="bi bi-chevron-right"></i>
            </a>
        </div>
    }

</div>

@section Scripts {
    <style>
        .dropdown-item:hover {
            background-color: #f8f9fa;
            transition: 0.2s;
        }

        .table-hover tbody tr:hover {
            background-color: rgba(13, 110, 253, 0.02);
        }
    </style>
}