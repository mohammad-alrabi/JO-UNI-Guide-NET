@model JO_UNI_Guide.Models.Faculty

@{
    ViewData["Title"] = "Create Faculty";
    Layout = "_AdminLayout";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="form-card shadow-sm p-4 bg-white rounded-4">

                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4 border-bottom pb-3">
                    <div>
                        <h2 class="page-title mb-1">Add Faculty</h2>
                        <p class="text-muted mb-0">Create a new faculty and assign it to a university.</p>
                    </div>

                    <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
                        <i class="bi bi-arrow-left me-2"></i> Back
                    </a>
                </div>

                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="row g-3">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Name" class="form-label fw-bold">Faculty Name</label>
                            <input asp-for="Name" class="form-control custom-input" placeholder="e.g. Faculty of IT" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="University_ID" class="form-label fw-bold">University</label>
                            <select asp-for="University_ID" class="form-select custom-input" asp-items="@(ViewData["University_ID"] as SelectList)">
                                <option value="">-- Select University --</option>
                            </select>
                            <span asp-validation-for="University_ID" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Faculty_Dean" class="form-label fw-bold">Faculty Dean</label>
                            <input asp-for="Faculty_Dean" class="form-control custom-input" placeholder="e.g. Dr. Ahmad Al-Ali" />
                            <span asp-validation-for="Faculty_Dean" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="Location" class="form-label fw-bold">Location / Building</label>
                            <input asp-for="Location" class="form-control custom-input" placeholder="e.g. Building B, 2nd Floor" />
                            <span asp-validation-for="Location" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Details" class="form-label fw-bold">Details & Description</label>
                        <textarea asp-for="Details" class="form-control custom-input" rows="4" placeholder="Write a brief description about this faculty..."></textarea>
                        <span asp-validation-for="Details" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 rounded-pill py-2 fw-bold fs-5 shadow-sm">
                        <i class="bi bi-check-circle me-2"></i> Save Faculty
                    </button>
                </form>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}